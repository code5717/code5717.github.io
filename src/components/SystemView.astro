---
import { profile } from '../data/profile';
---

<div id="view-sys" class="view-panel active">
  <p class="view-cmd">$ cat /sys/identity</p>

  <div class="sys-hero">
    <img src="/imgs/pfp.webp" alt="Portrait of Abdussamad Farooq Saeed" class="profile-image" width="220" height="220" decoding="async" />
    <div class="sys-hero-info">
      <h1 class="sys-name">{profile.name}</h1>
      <p class="sys-headline">{profile.headline}</p>
    </div>
  </div>

  <p class="sys-about">{profile.about}</p>

  <div class="sys-meta">
    <div class="sys-links-grid">
      <button id="copyEmailButton" class="sys-link-item" type="button" data-email={profile.contacts.email}>
        <span class="sys-link-label">email</span><span class="sys-link-action">[copy]</span>
      </button>
      <a href={profile.contacts.github} target="_blank" rel="noopener noreferrer" class="sys-link-item">
        <span class="sys-link-label">github</span><span class="sys-link-action">[link]</span>
      </a>
      <a href={profile.contacts.linkedin} target="_blank" rel="noopener noreferrer" class="sys-link-item">
        <span class="sys-link-label">linkedin</span><span class="sys-link-action">[link]</span>
      </a>
      <a href="/RESUME-ABDUSSAMAD-FEB-2026.pdf" target="_blank" rel="noopener noreferrer" class="sys-link-item">
        <span class="sys-link-label">resume</span><span class="sys-link-action">[link]</span>
      </a>
      <div class="sys-link-item sys-link-static">
        <span class="sys-link-label">location</span><span class="sys-link-value">{profile.location}</span>
      </div>
      <div class="sys-link-item sys-link-static">
        <span class="sys-link-label">citizenship</span><span class="sys-link-value">{profile.citizenship}</span>
      </div>
    </div>
    <div class="sys-lang-bar">
      <span class="sys-link-label">languages</span>
      <span class="sys-lang-values">
        {profile.languages.map((l, i) => <>
          <span class="sys-lang-name">{l.name}</span>
          <span class="sys-lang-fluency">({l.fluency})</span>
          {i < profile.languages.length - 1 && <span class="sys-lang-sep">·</span>}
        </>)}
      </span>
    </div>
  </div>
</div>
