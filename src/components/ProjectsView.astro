---
import { profile } from '../data/profile';
---

<div id="view-proj" class="view-panel">
  <p class="view-cmd">$ ls ~/projects</p>
  <div class="proj-list">
    {profile.projects.map((project, index) => (
      <div class="proj-entry">
        <div class="proj-row-shell">
          <button
            class={`proj-row ${index === 0 ? 'active' : ''}`}
            type="button"
            data-proj-index={index}
            aria-controls={`proj-detail-${index}`}
            aria-expanded={index === 0 ? 'true' : 'false'}
          >
            <span class="proj-period">{project.period}</span>
            <span class="proj-name">{project.name}</span>
          </button>
          {project.link && (
            <a href={project.link} target="_blank" rel="noopener noreferrer" class="proj-link-indicator">
              [link]
            </a>
          )}
        </div>
        <div id={`proj-detail-${index}`} class={`proj-detail-wrap ${index === 0 ? 'active' : ''}`} data-proj-detail={index} hidden={index !== 0}>
          <div class="proj-detail-inner">
            <ul>
              {project.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
            {project.link && (
              <a href={project.link} target="_blank" rel="noopener noreferrer" class="proj-detail-link">
                open repository &rarr;
              </a>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
